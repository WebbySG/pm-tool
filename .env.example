# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Supabase ───────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, NEVER prefix with NEXT_PUBLIC_
# Found in: Supabase dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ────────────────────────────────────────────────────────────────────────
# Full URL of your deployed app (used for invite email redirect links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Optional: Competitor Research APIs ────────────────────────────────────────
# Google PageSpeed Insights — https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PAGESPEED_KEY=your-google-api-key-here

# Open PageRank — https://www.domcop.com/openpagerank/documentation
OPENPAGERANK_KEY=your-openpagerank-key-here

# Meta Ads Library — https://developers.facebook.com/docs/marketing-api/reference/ads-archive
META_ACCESS_TOKEN=your-meta-access-token-here
